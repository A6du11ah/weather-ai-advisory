# WeatherAI API key. Create one at https://weather-ai.co dashboard.
# Keys are prefixed `wai_`. Server-side only — never expose this to the browser.
WEATHERAI_API_KEY=wai_your_key_here

# Base URL for the WeatherAI API.
WEATHERAI_BASE_URL=https://api.weather-ai.co

# Request AI-generated summaries via `ai=true`. The free tier returns null
# for this field regardless, but the plumbing is in place so a paid key
# lights it up with no code change. Set to "false" to skip the parameter.
ENABLE_AI_SUMMARY=true

# --- Optional: persistence (Phase 3) ---------------------------------------
# A Postgres connection string (Neon free tier works well). When set, the app
# reads forecasts from stored snapshots instead of calling the API on every
# page load, and day-over-day change detection turns on. Leave unset and the
# app runs entirely on the in-memory cache — no database required.
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Shared secret guarding the /api/cron/refresh endpoint. Set the SAME value
# here and as a GitHub Actions repository secret (with DEPLOYMENT_URL) so the
# scheduled job can trigger a refresh. Only needed alongside DATABASE_URL.
# CRON_SECRET=choose-a-long-random-string
