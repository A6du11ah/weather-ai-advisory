# WeatherAI API key. Create one at https://weather-ai.co dashboard.
# Keys are prefixed `wai_`. Server-side only — never expose this to the browser.
WEATHERAI_API_KEY=wai_your_key_here

# Base URL for the WeatherAI API.
WEATHERAI_BASE_URL=https://api.weather-ai.co

# Request AI-generated summaries via `ai=true`. The free tier returns null
# for this field regardless, but the plumbing is in place so a paid key
# lights it up with no code change. Set to "false" to skip the parameter.
ENABLE_AI_SUMMARY=true
